# ─────────────────────────────────────────────
#  Travel Buddy — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=5000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=travel_buddy

# JSON Web Token
JWT_SECRET=travel_buddy_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Groq AI API Key — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
